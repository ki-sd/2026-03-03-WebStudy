<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%--
	pageContext : PageContext 클래스의 객체
	웹 흐름 제어
	--------- 이동/첨부
	다른 객체 읽기
	
	=> pageContext.include() => JSP특정부분에 다른 JSP를 첨부
	   <jsp:include>
	     | => request를 공유한다
	=> pageContext.forward() => 화면 이동 (request를 유지)
	   : 화면 이동 => URL주소는 변경되지 않는다
	   <jsp:forward>
 --%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>

</body>
</html>